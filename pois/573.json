/algarve/fao0010_praia_de_santa_eulalia_0316_01.jpg","heroImage":"/-/media/destinations/poi/algarve/fao0010_praia_de_santa_eulalia_0316_01.jpg"},"location":{"description":"Albufeira, Algarve, Portugal","latitude":37.08797,"longitude":-8.21432},"summary":"A breathtaking clifftop overlooking a shingly length of sand and shallow waters. ","url":"/poi/algarve/praia-de-santa-eulalia","category":"Beaches"},{"code":"FAO0015","title":"Praia São Rafael","images":{"thumbnail":"/-/media/destinations/poi/algarve/fao0015_praia_sao_rafael_0316_01.jpg","heroImage":"/-/media/destinations/poi/algarve/fao0015_praia_sao_rafael_0316_01.jpg"},"location":{"description":"Albufeira, Algarve, Portugal","latitude":37.07469,"longitude":-8.280387},"summary":"Years of erosion have blessed São Rafael with some interesting rock formations, which means it’s popular with tourists. ","url":"/poi/algarve/praia-sao-rafael","category":"Beaches"},{"code":"FAO0034","title":"Sant'Ana Church","images":{"thumbnail":"/-/media/destinations/poi/algarve/fao0034_sant_ana_church_0316_01.jpg","heroImage":"/-/media/destinations/poi/algarve/fao0034_sant_ana_church_0316_01.jpg"},"location":{"description":"Albufeira, Algarve, Portugal","latitude":37.08785,"longitude":-8.255213},"summary":"Sant'Ana Church is steeped in history, as it was built in the 18th century. ","url":"/poi/algarve/santana-church","category":"Sights"},{"code":"FAO0068","title":"Silves Castle","images":{"thumbnail":"/-/media/fao_moorish_castle_silves_173844305_getty_rgb-136-dpi-for-web.jpg","heroImage":"/-/media/fao_moorish_castle_silves_173844305_getty_rgb-136-dpi-for-web.jpg"},"location":{"description":"Albufeira, Algarve, Portugal","latitude":37.19059,"longitude":-8.437948},"summary":"You can&rsquo;t miss this terracotta triumph that dominates the town&rsquo;s skyline. ","url":"/poi/algarve/silves-castle","category":"Sights"},{"code":"FAO0068","title":"Silves Cathedral","images":{"thumbnail":"/-/media/silves cathedral.png","heroImage":"/-/media/s