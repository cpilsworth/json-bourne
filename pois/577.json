real_de_santo antonio_499539421_rfis_1117_01.jpg"},"location":{"description":"Algarve, Portugal","latitude":37.19455,"longitude":-7.420902},"summary":"Want to experience the Algarve at its most authentic? ","url":"/poi/algarve/christmas-in-vila-real-de-santo-antonio","category":"Activities"},{"code":"FAO0063","title":"Day trip to Lisbon","images":{"thumbnail":"/-/media/destinations/poi/portugal/algarve/general/fao0063_day_trip_lisbon_rfis_0217_01.jpg","heroImage":"/-/media/destinations/poi/portugal/algarve/general/fao0063_day_trip_lisbon_rfis_0217_01.jpg"},"location":{"description":"Algarve, Portugal","latitude":37.01792,"longitude":-7.930755},"summary":"Europe’s second oldest city is perfect if you want the best of both worlds – city break and beach holiday. ","url":"/poi/algarve/day-trip-to-lisbon","category":"Activities"},{"code":"FAO0064","title":"Day trip to Seville","images":{"thumbnail":"/-/media/destinations/poi/portugal/algarve/general/fao0064_day_trip_seville_532854259_rfis_0217_01.jpg","heroImage":"/-/media/destinations/poi/portugal/algarve/general/fao0064_day_trip_seville_532854259_rfis_0217_01.jpg"},"location":{"description":"Algarve, Portugal","latitude":37.10746,"longitude":-8.676301},"summary":"Stroll down the cobbled streets of the Santa Cruz quarter, making your way to the Alcazar Palace drinking in the scent of orange blossom, or climb the steps in the Giralda tower for the view across the city. ","url":"/poi/algarve/day-trip-to-seville","category":"Activities"},{"code":"","title":"Ilha da Culatra","images":{"thumbnail":"/-/media/destinations/poi/faro/fao5031_ilha_da_culatra_1016_01.jpg","heroImage":"/-/media/destinations/poi/faro/fao5031_ilha_da_culatra_1016_01.jpg"},"location":{"description":"Algarve, Portugal","latitude":36.98891,"longitude":-7.833611},"summary":"Grab your beach parasol and head to Ilha da Culatra for the day. ","url":"/poi/algarve/ilha-da-culatra","category":"Sights"},{"code":"FAO0243","title":"Loulé Carnival","images":{"thumb