ng_1015_01.jpg"},"location":{"description":"Praia Da Rocha, Algarve, Portugal","latitude":37.11584,"longitude":-8.528884},"summary":"Get a close-up of the show as local dolphins play and somersault from the waves on a dolphin safari from Portim&atilde;o marina. ","url":"/poi/algarve/dolphin-watching","category":"Sights"},{"code":"FAO0141","title":"Fortress of Santa Catarina","images":{"thumbnail":"/-/media/destinations/poi/algarve/fao0141_fortress_of_sana_catarina_0316_01.jpg","heroImage":"/-/media/destinations/poi/algarve/fao0141_fortress_of_sana_catarina_0316_01.jpg"},"location":{"description":"Praia Da Rocha, Algarve, Portugal","latitude":37.11659,"longitude":-8.529533},"summary":"The Fortress of Santa Catarina de Ribamar kept watch over the mouth of the river Arade and defended Portimão from invaders. ","url":"/poi/algarve/fortress-of-santa-catarina","category":"Sights"},{"code":"FAO0133","title":"Marina de Portimao","images":{"thumbnail":"/-/media/destinations/poi/algarve/fao0133_marina_de_portimao_0316_01.jpg","heroImage":"/-/media/destinations/poi/algarve/fao0133_marina_de_portimao_0316_01.jpg"},"location":{"description":"Praia Da Rocha, Algarve, Portugal","latitude":37.12154,"longitude":-8.526463},"summary":"Portimão marina is a favourite among superyacht owners, capable of accommodating 620 yachts at a soaring 50 metres high. ","url":"/poi/algarve/marina-de-portimao","category":"Activities"},{"code":"FAO0131","title":"Nights at NoSoloAgua ","images":{"thumbnail":"/-/media/destinations/poi/algarve/fao0131_no_solo_agua_0316_01.jpg","heroImage":"/-/media/destinations/poi/algarve/fao0131_no_solo_agua_0316_01.jpg"},"location":{"description":"Praia Da Rocha, Algarve, Portugal","latitude":37.1154,"longitude":-8.527581},"summary":"NoSoloAgua is a bar and restaurant in Portim&atilde;o with panoramic views of Praia da Rocha&rsquo;s beach. ","url":"/poi/algarve/nights-at-nosoloagua","category":"Nightlife"},{"code":"FAO0134","title":"Ocean Revival Underwater Park","ima